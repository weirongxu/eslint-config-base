{
  "name": "@raidou/eslint-config-base",
  "version": "4.3.0",
  "main": "./dist/index.js",
  "license": "MIT",
  "repository": "git@github.com:weirongxu/eslint-config-base.git",
  "engines": {
    "node": ">=14.0.0"
  },
  "scripts": {
    "test": "pnpm run test:types && pnpm run test:lint && pnpm run test:unit",
    "test:types": "tsc --noEmit",
    "test:lint": "eslint",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.build.json",
    "prebuild": "pnpm run eject:rules",
    "prepublish": "pnpm run build",
    "eject:rules": "tsx scripts/eject-rules.ts"
  },
  "files": [
    "eslint.config.mjs",
    "dist/index.js",
    "dist/index.d.ts",
    "dist/eject-rules.js",
    "dist/eject-rules.d.ts",
    "dist/tests/helper.js",
    "dist/tests/helper.d.ts",
    "dist/tests/setup.js",
    "dist/tests/setup.d.ts"
  ],
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "typescript-eslint": "^8.53.0"
  },
  "devDependencies": {
    "@eslint/core": "^1.1.1",
    "@types/node": "^25.5.0",
    "dedent": "^1.7.2",
    "eslint": "^10.1.0",
    "prettier": "^3.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  }
}
